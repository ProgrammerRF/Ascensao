<Cadastro>:
	# FloatLayout define o layout da tela
	FloatLayout:
		pos_hint:{"top":1, "right":1}
		size_hint:1,1
		
		# Canvas define o plano de fundo
		canvas.before:
			Color:
				rgba: 1,1,1,1
			Rectangle:
				pos:self.pos
				size:self.size
				source: app.rp("assets/images/imagens/auroracadastro.png")
		
		# Botão do texto de voltar
		Button:
			pos_hint: {"top": 0.96, "right": 0.12}
			size_hint:0.10, 0.04
			background_color:0,0,0,0
			on_press: app.alterar_tela("login")

			
		# Entrada de dados do usuario para escrever o Email
		TextInput:
			id: email
			hint_text: "Digite seu E-mail"
			pos_hint: {"top": 0.525, "right": 0.63}
			size_hint: 0.23, 0.04
			multiline: False
			background_color:0,0,0,0
			foreground_color:1,1,1,1
		
		# Entrada de dados para o usuario escrever o nome
		TextInput:
			id: nome
			hint_text: "Digite seu nome"
			pos_hint: {"top": 0.46, "right": 0.63}
			size_hint: 0.23, 0.04
			multiline: False
			background_color:0,0,0,0
			foreground_color:1,1,1,1
		
		# Entrada de dados que permite o usuario escrever a senha
		TextInput:
			id: senha1
			hint_text: "Digite sua senha"
			pos_hint: {"top": 0.40, "right": 0.63}
			size_hint: 0.23, 0.04
			multiline: False
			password: True
			background_color:0,0,0,0
			foreground_color:1,1,1,1
			
		# Botão que executa a função de alterar a imagem e o tipo de entrada de dados da senha1
		Button:
			text:""
			pos_hint: {"top": 0.40, "right": 0.65}
			size_hint: 0.05, 0.04
			background_color: 0,0,0,0
			on_press: root.mostrarsenha1()
			
		# Entrada de dados que permite o usuario escrever a senha novamente
		TextInput:
			id: senha2
			hint_text: "Digite sua senha novamente"
			pos_hint: {"top": 0.33, "right": 0.63}
			size_hint: 0.23, 0.04
			multiline: False
			password: True
			background_color:0,0,0,0
			foreground_color:1,1,1,1
		
		# Botão que executa a função de alterar a imagem de mostrar/esconder senha e altera o tipo de dados de senha2
		Button:
			text:""
			pos_hint: {"top": 0.33, "right": 0.65}
			size_hint: 0.05, 0.04
			background_color: 0,0,0,0
			on_press:root.mostrarsenha2()
			
		# Texto que mostra as mensagens de erro
		Label:
			id: erro
			text: ""
			color: 1,0,0,1
			pos_hint: {"top": 0.07, "right": 1}
			size_hint: 1, 0.05
			font_size: 28
		
		# Botão da tela de cadastro
		Button:
			id:cadastrar
			pos_hint: {"top": 0.28, "right": 0.570}
			size_hint: 0.15, 0.05
			background_color: 0,0,0,0
			on_press: app.alterar_tela("principal") if root.cadastrar() == True else print("erro")
		
			
			