<Login>:
	# Plano de fundo
	FloatLayout:
		pos_hint:{"top":1, "right":1}
		size_hint:1,1
		
		canvas.before:
			Color:
				rgba: 1,1,1,1
			Rectangle:
				pos:self.pos
				size:self.size
			    source: app.rp("assets/images/imagens/aurora5.png")

		# Texto de saida
		Label:
			text: "Sair"
			pos_hint:{"top": 1.43, "right":0.60}
			size_hint:1,1
			font_size:28
		
		# Botão que executa o método saida()
		Button:
			pos_hint:{"top":0.95, "right":0.18}
			size_hint:0.15, 0.04
			background_color:0,0,0,0
			on_press: root.saida()
		
		# Icone do botão da tela de configuração
		Image:
			id:ativar_audio
			source: app.rp("assets/icons/ativar_audio.png")
			pos_hint:{"top":0.96,"right":0.92}
			size_hint:0.05,0.05
		
		# Botão da tela de configuração
		Button:
			pos_hint:{"top":0.98, "right": 0.92}
			size_hint:0.07, 0.07
			background_color:0,0,0,0
			on_press: root.alterar_estado()
		
		# Entrada de dados
		# Email
		TextInput:
			id: email
			hint_text:"Digite seu E-mail"
			pos_hint:{"top": 0.42, "right":0.87}
			size_hint:0.23,0.06
			multiline: False
			background_color:0,0,0,0
			foreground_color: 1,1,1,1
			
		# Entrada de dados que recebe a senha
		TextInput:
			id: senha
			hint_text:"Digite sua senha"
			pos_hint:{"top": 0.34, "right":0.87}
			size_hint:0.23,0.06
			multiline: False
			password: True
			background_color:0,0,0,0
			foreground_color:1,1,1,1
		
		# Botão invisível que executa a mudança do icone de mostrar/esconder senha e altera o valor boleano do password da senha
		Button:
			text:""
			pos_hint:{"top": 0.34, "right": 0.86}
			size_hint: 0.03, 0.04
			background_color: 0,0,0,0
			on_press: root.mostrarsenha()
			
		# Aviso
		# Texto que contem a mensagem de erro
		Label:
			id: erro
			text: ""
			color:1,0,0,1
			pos_hint: {"top": 0.08, "right": 1}
			size_hint: 1, 0.05
			font_size:28
		
		#  Botões
			
		# Botão de login
		Button:
			id:login
			pos_hint:{"top": 0.27, "right": 0.872}
			size_hint: 0.13, 0.06
			background_color: 0,0,0,0
			on_press: app.alterar_tela("principal") if root.validar() == True else print("erro") # Executa a função validar quando o botão é pressionado
		
		# Botão de cadastro
		Button:
			pos_hint:{"top": 0.27, "right": 0.725}
			size_hint: 0.13, 0.06
			background_color:0,0,0,0
			on_press: app.alterar_tela("cadastro")
			
			