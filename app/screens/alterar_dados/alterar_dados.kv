<Alterar_Dados>:
	# Cria um Layout que comporta os widgets da tela de alterar dados
	FloatLayout:
		pos_hint:{"top": 1, "right": 1}
		size_hint:1,1

		# Cria um plano de fundo
		canvas.before:
			Color:
				rgba:1,1,1,1
			Rectangle:
				pos: self.pos
				size: self.size
				source: app.rp("assets/images/imagens/auroraa.png")

		# Cria um botão invisivel na mesma posição do texto voltar com a funcionalidade de retornar para a tela de configuração
		Button:
			pos_hint:{"top": 0.96, "right": 0.12}
			size_hint:0.10, 0.04
			background_color: 0,0,0,0
			on_press: app.alterar_tela("configuracao")

		# Cria uma entrada de dados que recebe email antigo
		TextInput:
			id:email_antigo
			pos_hint:{"top": 0.50, "right": 0.62}
			size_hint:0.23, 0.04
			multiline:False
			disabled: True
			background_color:1,1,1,1

		TextInput:
		    id: email_novo
		    pos_hint:{"top": 0.43, "right": 0.62}
		    size_hint: 0.23, 0.04
		    multiline: False
		    background_color:0,0,0,0
		    foreground_color:1,1,1,1

		# Cria uma entrada de dados que recebe o nome o usuario
		TextInput:
			id:nome
			pos_hint:{"top":0.37, "right":0.62}
			size_hint:0.23, 0.04
			multiline:False
			background_color:0,0,0,0
		    foreground_color:1,1,1,1

		# Cria uma entrada de dados que recebe a senha do usuario
		TextInput:
			id:senha
			pos_hint:{"top": 0.30, "right": 0.62}
			size_hint:0.23, 0.04
			multiline:False
			password: True
			background_color:0,0,0,0
		    foreground_color:1,1,1,1

		# Botão invisivel que fica na mesma posição do icone mostrar/ocultar senha
		Button:
			pos_hint:{"top": 0.30, "right": 0.63}
			size_hint: 0.05, 0.04
			background_color: 0,0,0,0
			on_press: root.mostrar_senha()

		# Texto que contem as mensagens de erro

		Label:
			id:erro
			text: ""
			pos_hint:{"top":0.07, "right":1}
			size_hint:1,0.05
			color:1,0,0,1
			font_size:28

		# Botão invisivel na mesma posição da imagem de fundo e do texto do botão salvar alterações que chama a função validar quando pressionado
		Button:
			id:botao
			pos_hint:{"top": 0.25, "right": 0.570}
			size_hint:0.15, 0.05
			background_color: 0,0,0,0
			on_press: app.alterar_tela("configuracao") if root.validar() == True else print("erro")



